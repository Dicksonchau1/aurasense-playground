{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["hkg1"],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self)" }
      ]
    },
    {
      "source": "/rehearse-nurse",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self)" }
      ]
    },
    {
      "source": "/rehearse-nurse/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self)" }
      ]
    }
  ]
}
