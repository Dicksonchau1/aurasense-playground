{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/components/*": [
        "./components/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src",
    "components",
    "lib",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
    "**/*.mts"
}
  "exclude": [
    "node_modules"
  ]
}
