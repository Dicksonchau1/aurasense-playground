{
  "$id": "axes.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "title": "DiscreteAxis",
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,40}$" },
        "label": { "type": "string", "minLength": 1, "maxLength": 64 },
        "unit": { "type": "string", "maxLength": 16 },
        "type": { "const": "discrete" },
        "enabled": { "type": "boolean" },
        "seed_count": { "type": "integer", "minimum": 1, "maximum": 32 },
        "importance": { "type": "string", "enum": ["low", "med", "high"] },
        "values": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 64, "uniqueItems": true }
      },
      "required": ["id", "label", "type", "enabled", "values"],
      "additionalProperties": false
    },
    {
      "title": "ContinuousAxis",
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,40}$" },
        "label": { "type": "string", "minLength": 1, "maxLength": 64 },
        "unit": { "type": "string", "maxLength": 16 },
        "type": { "const": "continuous" },
        "enabled": { "type": "boolean" },
        "seed_count": { "type": "integer", "minimum": 1, "maximum": 32 },
        "importance": { "type": "string", "enum": ["low", "med", "high"] },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number", "exclusiveMinimum": 0 },
        "scale": { "type": "string", "enum": ["linear", "log"] }
      },
      "required": ["id", "label", "type", "enabled", "min", "max", "step"],
      "additionalProperties": false
    },
    {
      "title": "CategoricalAxis",
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,40}$" },
        "label": { "type": "string", "minLength": 1, "maxLength": 64 },
        "unit": { "type": "string", "maxLength": 16 },
        "type": { "const": "categorical" },
        "enabled": { "type": "boolean" },
        "seed_count": { "type": "integer", "minimum": 1, "maximum": 32 },
        "importance": { "type": "string", "enum": ["low", "med", "high"] },
        "values": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 32, "uniqueItems": true }
      },
      "required": ["id", "label", "type", "enabled", "values"],
      "additionalProperties": false
    }
  ]
}
