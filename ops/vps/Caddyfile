{
    # Global options
    email you@yourdomain.com
    admin off
}

# ── NEPA backend domain ──────────────────────────────────────────────────────
nepa.YOURDOMAIN.com {
    encode zstd gzip

    # Health endpoint always passes through to whichever node answers first
    @health path /health
    handle @health {
        reverse_proxy {
            to 127.0.0.1:18080      # Jetson via reverse SSH tunnel
            # to gpu-pod.YOURDOMAIN.com:443  # uncomment when GPU pod is up
            lb_policy first
            health_uri /health
            health_interval 15s
            health_timeout 5s
            health_status 2xx
        }
    }

    # All inference + SSE traffic
    handle {
        reverse_proxy {
            to 127.0.0.1:18080
            # to gpu-pod.YOURDOMAIN.com:443

            lb_policy least_conn          # spread load when multiple backends
            lb_try_duration 5s
            lb_try_interval 250ms

            health_uri      /health
            health_interval 15s
            health_timeout  5s
            health_status   2xx

            # SSE-friendly
            flush_interval -1

            transport http {
                keepalive 90s
                response_header_timeout 5m
                read_timeout 5m
                write_timeout 5m
            }

            # Forward auth header from Vercel through to the backend
            header_up Authorization {http.request.header.Authorization}

            # Identify which backend served the request (debugging)
            header_down X-NEPA-Upstream {http.reverse_proxy.upstream.hostport}
        }
    }

    log {
        output file /var/log/caddy/nepa.log {
            roll_size 50mb
            roll_ output file /var/log/caddy/nepa.log {
            roll_size 50mb
            roll_keep 7
            roll_keep_for 720h
        }
        format json
    }
}
