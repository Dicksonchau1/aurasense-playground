{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@aurasense/*": ["packages/*/src"],
      "@/lib/*": ["apps/www/lib/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "out"],
  "include": ["apps/*/src", "packages/*/src"]
}
