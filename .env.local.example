NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── NEPA Runtime Bridge ───────────────────────────────────────────────────
# Mode: grpc | triton | http | mock  (default: mock)
NEPA_RUNTIME_MODE=mock
NEPA_RUNTIME_URL=http://jetson-edge.local:8080
NEPA_RUNTIME_GRPC=jetson-edge.local:50051
NEPA_RUNTIME_TRITON=http://triton.local:8000
NEPA_RUNTIME_TIMEOUT_MS=8000
NEPA_RUNTIME_TOKEN=

# ── Live anomaly stream (Redis pub/sub or fallback in-memory) ─────────────
NEPA_ANOMALY_REDIS_URL=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# App URL for Stripe redirects (use ngrok / vercel preview / prod domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000
